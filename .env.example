# Google OAuth Configuration
# Obtain these values from Google Cloud Console (https://console.cloud.google.com/)
# 
# Steps to obtain Google OAuth credentials:
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project or select an existing one
# 3. Enable Google Sign-In API for your project
# 4. Go to "Credentials" section
# 5. Create OAuth 2.0 Client IDs for:
#    - Web application (for GOOGLE_WEB_CLIENT_ID)
#    - iOS application (for GOOGLE_IOS_CLIENT_ID)
#    - Android application (for GOOGLE_ANDROID_CLIENT_ID)
# 
# Web Client ID (required for both iOS and Android)
GOOGLE_WEB_CLIENT_ID=your_web_client_id_here.apps.googleusercontent.com

# iOS Client ID (required for iOS)
GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here.apps.googleusercontent.com

# Android Client ID (optional, can use Web Client ID)
GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here.apps.googleusercontent.com

# JWT Secret Key (used for signing JWT tokens)
# Generate a secure random string for production use
JWT_SECRET=your_secure_jwt_secret_key_here
